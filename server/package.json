{
  "name": "@yapskippr/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run typecheck:admin && npm run build:admin && tsc -p tsconfig.json",
    "build:admin": "vite build --config admin/vite.config.ts",
    "migrate": "tsx src/db/migrate.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:dashboard": "npm run build && vitest run --config vitest.dashboard.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:admin": "tsc -p admin/tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/static": "latest",
    "@vitejs/plugin-react": "latest",
    "fastify": "latest",
    "lucide-react": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "playwright": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
