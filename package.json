{
  "name": "yapskippr",
  "version": "0.1.0",
  "description": "In-Video Sponsorship- and Ad-Skipper",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:installable": "node scripts/build-installable.mjs",
    "build:server": "npm --prefix server run build",
    "build:all": "npm run build && npm run build:server",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "vitest run",
    "test:server": "npm --prefix server test",
    "test:dashboard": "npm --prefix server run test:dashboard",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "npm --prefix server run typecheck",
    "server:dev": "npm --prefix server run dev",
    "server:migrate": "npm --prefix server run migrate",
    "coverage": "vitest run --coverage",
    "pretest:e2e": "npm run build && npm run build:firefox",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "jsqr": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/chrome": "latest",
    "@vitest/coverage-v8": "latest",
    "playwright": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wxt": "latest"
  }
}
